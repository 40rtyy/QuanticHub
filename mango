local function makeSlider(parent, y, text, minValue, maxValue, currentValue, callback)
	local row = create("Frame", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 0, 0, y),
		Size = UDim2.new(1, 0, 0, 42),
		Parent = parent,
	})
	local nameLabel = makeLabel(row, text, 12, nil, true)
