local function setSliderVisual(sliderData, value)
	local alpha = math.clamp((value - sliderData.minValue) / (sliderData.maxValue - sliderData.minValue), 0, 1)
	sliderData.fill.Size = UDim2.new(alpha, 0, 1, 0)
