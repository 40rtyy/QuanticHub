	local valueLabel = makeLabel(row, tostring(currentValue), 12, nil, true)
	valueLabel.AnchorPoint = Vector2.new(1, 0)
	valueLabel.Position = UDim2.new(1, 0, 0, 0)
	valueLabel.Size = UDim2.new(0.25, 0, 0, 16)
	valueLabel.TextXAlignment = Enum.TextXAlignment.Right
	local bar = create("Frame", {
		BackgroundColor3 = Color3.fromRGB(30, 30, 36),
		BorderSizePixel = 0,
		Position = UDim2.new(0, 0, 0, 24),
		Size = UDim2.new(1, 0, 0, 8),
		Parent = row,
	})
	addCorner(bar, 999)
	local fill = create("Frame", {
		BackgroundColor3 = Color3.fromRGB(180, 120, 255),
		BorderSizePixel = 0,
		Size = UDim2.new((currentValue - minValue) / (maxValue - minValue), 0, 1, 0),
		Parent = bar,
	})
	addCorner(fill, 999)
	table.insert(dynamicAccentObjects, fill)
	local knob = create("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		BackgroundColor3 = FIXED_TEXT,
		BorderSizePixel = 0,
		Position = UDim2.new((currentValue - minValue) / (maxValue - minValue), 0, 0.5, 0),
		Size = UDim2.new(0, 14, 0, 14),
		Parent = bar,
	})
	addCorner(knob, 999)
	local dragGhost = create("Frame", {
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		BackgroundTransparency = 0.99,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 2, 0, 2),
		Size = UDim2.new(1, -4, 1, -4),
		Parent = bar,
	})
	addCorner(dragGhost, 999)

	local sliderData = {
		bar = bar,
		fill = fill,
		knob = knob,
		valueLabel = valueLabel,
		dragGhost = dragGhost,
		minValue = minValue,
		maxValue = maxValue,
		callback = callback,
		currentValue = currentValue,
	}
	table.insert(sliderRegistry, sliderData)

	local function setFromX(x)
		local alpha = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
		local value = minValue + (maxValue - minValue) * alpha
		value = math.floor(value * 100) / 100
		sliderData.currentValue = value
		setSliderVisual(sliderData, value)
		callback(value)
	end

	bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			activeSlider = sliderData
			tween(dragGhost, 0.18, {BackgroundTransparency = 0.982})
			setFromX(input.Position.X)
		end
	end)

	sliderData.setValue = function(value)
		sliderData.currentValue = value
		setSliderVisual(sliderData, value)
		callback(value)
	end

	return sliderData
end

UserInputService.InputChanged:Connect(function(input)
	if activeSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
		local sliderData = activeSlider
		local alpha = math.clamp((input.Position.X - sliderData.bar.AbsolutePosition.X) / sliderData.bar.AbsoluteSize.X, 0, 1)
		local value = sliderData.minValue + (sliderData.maxValue - sliderData.minValue) * alpha
		value = math.floor(value * 100) / 100
		sliderData.currentValue = value
		setSliderVisual(sliderData, value)
		sliderData.callback(value)
	end
end)

