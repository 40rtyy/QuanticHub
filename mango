local function create(className, props)
	local obj = Instance.new(className)
	if props then
		for key, value in pairs(props) do
			obj[key] = value
		end
	end
	return obj
end

local function tween(obj, time, props, style, direction)
	local tw = TweenService:Create(
		obj,
		TweenInfo.new(time, style or Enum.EasingStyle.Sine, direction or Enum.EasingDirection.Out),
		props
	)
	tw:Play()
	return tw
end

local function addCorner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius)
	c.Parent = parent
	return c
end

local function addStroke(parent, color, transparency, thickness)
	local s = Instance.new("UIStroke")
	s.Color = color
	s.Transparency = transparency or 0
	s.Thickness = thickness or 1
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent = parent
	return s
end

local function addPadding(parent, left, right, top, bottom)
	local p = Instance.new("UIPadding")
	p.PaddingLeft = UDim.new(0, left)
	p.PaddingRight = UDim.new(0, right)
	p.PaddingTop = UDim.new(0, top)
	p.PaddingBottom = UDim.new(0, bottom)
	p.Parent = parent
	return p
end

local function getPanelSize()
	local width = math.floor(BASE_WIDTH * state.panelScale)
	local fullHeight = state.compactMode and COMPACT_HEIGHT or BASE_HEIGHT
	local height = state.minimized and MINIMIZED_HEIGHT or math.floor(fullHeight * state.panelScale)
	return width, height
end

local function makeLabel(parent, text, size, color, bold)
	local label = create("TextLabel", {
		BackgroundTransparency = 1,
		Text = text,
		TextSize = size,
		TextColor3 = color or FIXED_TEXT,
		TextTransparency = 0,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Center,
		Font = bold and Enum.Font.GothamBold or Enum.Font.Gotham,
		RichText = true,
	})
	label.Parent = parent
	table.insert(fadeTextObjects, label)
	return label
end

local function fadeInTextSet(list, delayStep)
	for i, obj in ipairs(list) do
		if obj and obj.Parent and obj:IsA("TextLabel") then
			obj.TextTransparency = 1
			task.delay((delayStep or 0.01) * i, function()
				if obj and obj.Parent then
					tween(obj, 0.28, {TextTransparency = 0}, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
				end
			end)
		end
	end
end

