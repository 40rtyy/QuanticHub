local function fadePageIn(page)
	for _, item in ipairs(page:GetDescendants()) do
		if item:IsA("TextLabel") then
			item.TextTransparency = 1
			tween(item, 0.3, {TextTransparency = 0})
		elseif item:IsA("Frame") or item:IsA("TextButton") then
			local current = item.BackgroundTransparency
			if current < 1 then
				item.BackgroundTransparency = math.min(1, current + 0.18)
				tween(item, 0.28, {BackgroundTransparency = current})
			end
		end
	end
end

