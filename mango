local runtimeStart = os.clock()
local runtimeAccum = 0

local hue = 0
local accum = 0
RunService.RenderStepped:Connect(function(dt)
	if not gui.Parent or not main.Parent then
		return
	end
	accum = accum + dt
	if accum < 0.05 then
		return
	end
	local step = accum
	accum = 0
	if state.rainbowGlow then
		hue = (hue + step * 0.1) % 1
	end
	local accent = Color3.fromHSV(hue, 0.45, 1)
	updateAccentTheme(accent)

	runtimeAccum = runtimeAccum + step
	if runtimeAccum >= 0.2 then
		runtimeAccum = 0
		local elapsed = math.floor(os.clock() - runtimeStart)
		local minutes = math.floor(elapsed / 60)
		local seconds = elapsed % 60
		statB.Text = string.format("%02d:%02d", minutes, seconds)
	end

	for _, particle in ipairs(particles) do
		particle.trail.Visible = particle.obj.Visible
		if particle.obj.Visible then
			particle.lastX = particle.x
			particle.lastY = particle.y
			particle.y = particle.y - particle.speed * step * 18
			if particle.y < -0.06 then
				particle.y = 1.06
				particle.x = math.random()
				particle.lastX = particle.x
				particle.lastY = particle.y
			end
			particle.obj.Position = UDim2.new(particle.x, 0, particle.y, 0)
			particle.trail.Position = UDim2.new(
				particle.lastX + (particle.x - particle.lastX) * 0.35,
				0,
				particle.lastY + (particle.y - particle.lastY) * 0.35 + 0.01,
				0
			)
		end
	end

	for _, star in ipairs(shootingStars) do
		if not star.active then
			star.timer = star.timer - step
			if star.timer <= 0 then
				star.active = true
				star.duration = math.random(8, 14) / 10
				star.timer = star.duration
				star.x = math.random(20, 80) / 100
				star.y = math.random(5, 30) / 100
				star.vx = 0.08 + math.random() * 0.05
				star.vy = 0.05 + math.random() * 0.03
				star.tail.BackgroundTransparency = 0.3
				star.tail.Position = UDim2.new(star.x, 0, star.y, 0)
			end
		else
			star.timer = star.timer - step
			star.x = star.x + star.vx * step
			star.y = star.y + star.vy * step
			star.tail.Position = UDim2.new(star.x, 0, star.y, 0)
			star.tail.BackgroundTransparency = 0.3 + ((star.duration - star.timer) / star.duration) * 0.7
			if star.timer <= 0 or star.x > 1.2 or star.y > 1.2 then
				star.active = false
				star.timer = math.random(25, 70) / 10
				star.tail.BackgroundTransparency = 1
				star.tail.Position = UDim2.new(-0.2, 0, -0.2, 0)
			end
		end
	end
end)

