local function updateTabVisuals()
	for name, btn in pairs(tabButtons) do
		local active = state.currentTab == name
		local accentBar = btn:FindFirstChild("Accent")
		btn.BackgroundColor3 = active and Color3.fromRGB(26, 26, 32) or Color3.fromRGB(16, 16, 20)
		if accentBar then
			accentBar.BackgroundTransparency = 1
			tween(accentBar, 0.24, {BackgroundTransparency = active and 0 or 1}, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
		end
		local labels = tabLabelMap[name]
		if labels then
			for _, lbl in ipairs(labels) do
				lbl.TextTransparency = active and 0 or 0.08
			end
		end
	end
	for name, page in pairs(pages) do
		page.Visible = state.currentTab == name
		if page.Visible then
			page.CanvasPosition = Vector2.new(0, 0)
			fadePageIn(page)
			local labels = tabLabelMap[name]
			if labels then
				for i, lbl in ipairs(labels) do
					lbl.TextTransparency = 1
					task.delay(0.03 * i, function()
						if lbl and lbl.Parent then
							tween(lbl, 0.26, {TextTransparency = 0}, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
						end
					end)
				end
			end
		end
	end
end

